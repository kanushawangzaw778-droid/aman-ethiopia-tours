rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == 'kanushawangzaw@gmail.com';
    }

    // Fields a regular (non-admin) user should never be able to modify
    function clientPaymentFieldsUnchanged() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(
        ['paymentStatus', 'status', 'receipt', 'paidAt', 'verifiedBy', 'confirmedAt']
      );
    }

    // Allows a booking owner to submit Telebirr proof fields only
    function validProofSubmit() {
      return request.auth != null
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['transactionId', 'receiptImage', 'proofSubmittedAt', 'paymentStatus', 'status', 'updatedAt'])
        && request.resource.data.paymentStatus == 'pending_review';
    }

    function validBookingCreate() {
      return request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.paymentStatus in ['pending', 'unpaid']
        && request.resource.data.status in ['pending', 'waiting_admin_confirmation'];
    }

    match /tours/{tourId} {
      allow read: if true;
      // Admin can write (create/update/delete) tours
      allow write: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow create: if validBookingCreate();
      allow read:   if request.auth != null
                      && (resource.data.userId == request.auth.uid || isAdmin());
      // Admin has full update access; regular users may only submit proof
      allow update: if isAdmin() || validProofSubmit();
      allow delete: if isAdmin();
    }

    match /messages/{messageId} {
      allow create: if true;
      allow read, update: if isAdmin();
    }

    match /subscribers/{subId} {
      allow create: if true;
      allow read: if isAdmin();
    }

    match /settings/{docId} {
      allow read, write: if isAdmin();
    }
  }
}
