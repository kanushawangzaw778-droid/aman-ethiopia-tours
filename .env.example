# Admin Login
VITE_ADMIN_EMAIL=kanushawangzaw@gmail.com
VITE_ADMIN_PASSWORD=kanu 12345

# Firebase Configuration
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Company Settings
VITE_WHATSAPP_NUMBER=251911000000
VITE_COMPANY_EMAIL=info@amanethiopiatours.com
VITE_COMPANY_PHONE=+251 989610664

# Stripe (International Payments)
# Backend (required for secure webhook verification)
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
# Option 1: Stripe Payment Link (fallback if checkout session API unavailable)
VITE_STRIPE_PAYMENT_LINK=https://buy.stripe.com/your_link
# Option 2: Stripe Publishable Key (legacy checkout)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_key

# Payment API (leave empty to use Vite proxy in dev: /api -> localhost:3001)
VITE_API_URL=
CLIENT_ORIGIN=http://localhost:5173
PORT=3001

# Firebase Admin SDK (backend only — never expose in frontend)
FIREBASE_SERVICE_ACCOUNT_JSON=
# Or: GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccount.json

# Telebirr (Local Ethiopia Payments)
VITE_TELEBIRR_MERCHANT_ID=your_merchant_id
VITE_TELEBIRR_API_URL=https://api.telebirr.et/v1/payments

# Notifications (optional webhook for email/Slack alerts)
VITE_NOTIFICATION_WEBHOOK=https://your-webhook-url.com/bookings

# EmailJS (optional email notifications)
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key

# SMTP (backend email notifications — recommended)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Aman Ethiopia Tours <noreply@amanethiopiatours.com>"
